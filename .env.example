# =============================================================================
# seismic-spread-monitor — 環境變數範本
# 複製此檔為 .env 並填入實際值：cp .env.example .env
# 警告：.env 已列入 .gitignore，切勿提交至 git
# =============================================================================

# -----------------------------------------------------------------------------
# [必填] 部署者 / 互動者的錢包私鑰
# 格式：0x 開頭的 64 位十六進位字串
# 用途：script/deploy.sh 部署合約、script/interact.sh 發送交易
# -----------------------------------------------------------------------------
PRIVATE_KEY=

# -----------------------------------------------------------------------------
# [網路設定] Seismic devnet RPC 節點 URL
# 預設值：https://node-2.seismicdev.net/rpc
# 若要切換節點或使用其他環境，請修改此值
# -----------------------------------------------------------------------------
RPC_URL=https://node-2.seismicdev.net/rpc

# -----------------------------------------------------------------------------
# [合約地址] 已部署的 SpreadMonitor 合約地址
# 執行 script/deploy.sh 後，將輸出的 "Contract Address" 填入此處
# 用途：script/interact.sh 指定呼叫目標
# -----------------------------------------------------------------------------
CONTRACT_ADDRESS=

# -----------------------------------------------------------------------------
# [工具路徑] scast 二進位檔的完整路徑
# 預設值：$HOME/.seismic/bin/scast
# 若 sFoundry 安裝在非預設路徑，請修改此值
# -----------------------------------------------------------------------------
SCAST_PATH=$HOME/.seismic/bin/scast

# -----------------------------------------------------------------------------
# [策略參數] 監控的交易對合約地址（saddress，上鏈後為私密欄位）
# 範例：使用任意 ERC-20 pair 地址，測試可填 0x0000000000000000000000000000000000000001
# -----------------------------------------------------------------------------
PAIR_ADDR=

# -----------------------------------------------------------------------------
# [策略參數] 價差觸發閾值（suint256，上鏈後為私密欄位）
# 單位：bps（basis points），例如 100 = 1.00%，50 = 0.50%
# -----------------------------------------------------------------------------
THRESHOLD=100
