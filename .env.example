# =============================================================================
# seismic-spread-monitor — Environment Variables Template
# Copy this file to .env and fill in the actual values: cp .env.example .env
# Warning: .env is listed in .gitignore — never commit it to git
# =============================================================================

# -----------------------------------------------------------------------------
# [Required] Wallet private key for the deployer / interactor
# Format: 64-character hex string prefixed with 0x
# Used by: script/deploy.sh (contract deployment), script/interact.sh (send transactions)
# -----------------------------------------------------------------------------
PRIVATE_KEY=

# -----------------------------------------------------------------------------
# [Network] Seismic devnet RPC node URL
# Default: https://node-2.seismicdev.net/rpc
# Change this value if you want to switch nodes or target a different environment
# -----------------------------------------------------------------------------
RPC_URL=https://node-2.seismicdev.net/rpc

# -----------------------------------------------------------------------------
# [Contract] Deployed SpreadMonitor contract address
# After running script/deploy.sh, paste the "Contract Address" from the output here
# Used by: script/interact.sh to specify the call target
# -----------------------------------------------------------------------------
CONTRACT_ADDRESS=

# -----------------------------------------------------------------------------
# [Tool Path] Full path to the scast binary
# Default: $HOME/.seismic/bin/scast
# Change this value if sFoundry is installed in a non-default location
# -----------------------------------------------------------------------------
SCAST_PATH=$HOME/.seismic/bin/scast

# -----------------------------------------------------------------------------
# [Strategy] Monitored trading pair contract address (saddress — private on-chain field)
# Example: any ERC-20 pair address; use 0x0000000000000000000000000000000000000001 for testing
# -----------------------------------------------------------------------------
PAIR_ADDR=

# -----------------------------------------------------------------------------
# [Strategy] Spread trigger threshold (suint256 — private on-chain field)
# Unit: bps (basis points), e.g. 100 = 1.00%, 50 = 0.50%
# -----------------------------------------------------------------------------
THRESHOLD=100
